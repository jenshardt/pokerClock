# Copy this file to .env and set secure values before running docker compose.
# Keep .env out of version control.

POSTGRES_PASSWORD=change-me-to-a-strong-password
DB_PASSWORD=change-me-to-a-strong-password

# Optional admin seed user for local/dev only.
# Leave empty to disable automatic user seeding.
APP_SEED_ADMIN_USERNAME=
APP_SEED_ADMIN_PASSWORD=
APP_SEED_ADMIN_ROLE=ADMIN
